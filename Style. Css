body {
  font-family: Arial, sans-serif;
  background: #f4f6f8;
  margin: 0;
  padding: 0;
}

.container {
  max-width: 700px;
  margin: auto;
  padding: 20px;
}

h1 {
  text-align: center;
}

.welcome {
  text-align: center;
  color: #555;
}

.activity {
  background: white;
  padding: 15px;
  margin: 10px 0;
  border-radius: 8px;
  box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.activity h3 {
  margin: 0;
}

.status {
  font-size: 14px;
  margin: 5px 0;
}

.completed {
  color: green;
}

.pending {
  color: red;
}

button {
  padding: 8px 12px;
  border: none;
  background: #007bff;
  color: white;
  border-radius: 5px;
  cursor: pointer;
}

button:hover {
  background: #0056b3;
}

.progress-box {
  margin: 20px 0;
}

.progress-bar {
  width: 100%;
  height: 10px;
  background: #ddd;
  border-radius: 5px;
}

#progressFill {
  height: 10px;
  background: green;
  width: 0%;
  border-radius: 5px;
}

@media (max-width: 600px) {
  .container {
    padding: 10px;
  }
}
